{
  "name": "Hayku Identity — OIDC + MFA + Provider 測試",
  "base_url": "http://localhost:3100",
  "stop_on_error": true,
  "_note": "authorize POST（form）與 SSO cookie 流程需瀏覽器或 curl，見 tests/oidc-manual.md",
  "steps": [
    {
      "name": "OIDC Discovery — 回傳標準 metadata",
      "method": "GET",
      "path": "/.well-known/openid-configuration",
      "assert": {
        "status": 200,
        "body.issuer": "http://localhost:3100",
        "body.authorization_endpoint": "$exists",
        "body.token_endpoint": "$exists",
        "body.jwks_uri": "$exists",
        "body.userinfo_endpoint": "$exists",
        "body.id_token_signing_alg_values_supported": "$exists",
        "body.code_challenge_methods_supported": "$exists"
      }
    },
    {
      "name": "JWKS — 回傳 RSA 公鑰",
      "method": "GET",
      "path": "/oauth/jwks",
      "assert": {
        "status": 200,
        "body.keys": "$exists"
      }
    },
    {
      "name": "Authorize — 無 response_type 應回 400",
      "method": "GET",
      "path": "/oauth/authorize?client_id=hayku-dev-client&redirect_uri=http://localhost:3000/callback",
      "assert": {
        "status": 400
      }
    },
    {
      "name": "Authorize — 無效 client_id 應回 400",
      "method": "GET",
      "path": "/oauth/authorize?response_type=code&client_id=nonexistent&redirect_uri=http://localhost:3000/callback&scope=openid",
      "assert": {
        "status": 400
      }
    },
    {
      "name": "Authorize — 未登錄的 redirect_uri 應回 400",
      "method": "GET",
      "path": "/oauth/authorize?response_type=code&client_id=hayku-dev-client&redirect_uri=http://evil.com/hack&scope=openid",
      "assert": {
        "status": 400
      }
    },
    {
      "name": "Authorize — 合法請求無 session 應顯示登入頁（200）",
      "method": "GET",
      "path": "/oauth/authorize?response_type=code&client_id=hayku-dev-client&redirect_uri=http://localhost:3000/callback&scope=openid+profile&state=abc",
      "assert": {
        "status": 200
      }
    },
    {
      "name": "Token — 無效 grant_type 應回 400",
      "method": "POST",
      "path": "/oauth/token",
      "body": {
        "grant_type": "password",
        "username": "admin",
        "password": "test"
      },
      "assert": {
        "status": 400,
        "body.error": "unsupported_grant_type"
      }
    },
    {
      "name": "Token — 無效 code 應回 400",
      "method": "POST",
      "path": "/oauth/token",
      "body": {
        "grant_type": "authorization_code",
        "code": "invalidcode",
        "client_id": "hayku-dev-client",
        "redirect_uri": "http://localhost:3000/callback"
      },
      "assert": {
        "status": 400,
        "body.error": "invalid_grant"
      }
    },
    {
      "name": "Token — 無效 client_id 應回 401",
      "method": "POST",
      "path": "/oauth/token",
      "body": {
        "grant_type": "authorization_code",
        "code": "anycode",
        "client_id": "bad-client",
        "redirect_uri": "http://localhost:3000/callback"
      },
      "assert": {
        "status": 401,
        "body.error": "invalid_client"
      }
    },
    {
      "name": "UserInfo — 無 token 應回 401",
      "method": "GET",
      "path": "/oauth/userinfo",
      "assert": {
        "status": 401
      }
    },
    {
      "name": "UserInfo — 無效 token 應回 401",
      "method": "GET",
      "path": "/oauth/userinfo",
      "headers": {
        "Authorization": "Bearer invalidtoken"
      },
      "assert": {
        "status": 401
      }
    },
    {
      "name": "UserInfo — HS256 token（舊版 API token）應回 401",
      "method": "GET",
      "path": "/oauth/userinfo",
      "headers": {
        "Authorization": "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJ0ZXN0In0.fake"
      },
      "assert": {
        "status": 401
      }
    },
    {
      "name": "MFA Status — 未認證應回 401",
      "method": "GET",
      "path": "/auth/mfa/status",
      "assert": {
        "status": 401
      }
    },
    {
      "name": "MFA Enroll — 未認證應回 401",
      "method": "POST",
      "path": "/auth/mfa/enroll",
      "assert": {
        "status": 401
      }
    },
    {
      "name": "MFA VerifyEnroll — 未認證應回 401",
      "method": "POST",
      "path": "/auth/mfa/verify-enroll",
      "body": { "code": "123456" },
      "assert": {
        "status": 401
      }
    },
    {
      "name": "MFA Delete — 未認證應回 401",
      "method": "DELETE",
      "path": "/auth/mfa",
      "body": { "code": "123456" },
      "assert": {
        "status": 401
      }
    },
    {
      "name": "MFA Verify（登入流程）— 無效 pending_token 應回 400",
      "method": "POST",
      "path": "/oauth/mfa-verify",
      "body": {
        "pending_token": "invalid-token",
        "code": "123456"
      },
      "assert": {
        "status": 400
      }
    },
    {
      "name": "External Provider — 不存在的 provider 應回 404",
      "method": "GET",
      "path": "/oauth/external-start/nonexistent?response_type=code&client_id=hayku-dev-client&redirect_uri=http://localhost:3000/callback&scope=openid",
      "assert": {
        "status": 404
      }
    },
    {
      "name": "External Callback — 不存在的 provider 應回 404",
      "method": "GET",
      "path": "/oauth/callback/nonexistent?code=abc&state=def",
      "assert": {
        "status": 404
      }
    },
    {
      "name": "OIDC Clients — 未認證應回 401",
      "method": "GET",
      "path": "/auth/oidc-clients",
      "assert": {
        "status": 401
      }
    },
    {
      "name": "OIDC Clients — 非 superAdmin 應回 401（無 token）",
      "method": "POST",
      "path": "/auth/oidc-clients",
      "body": {
        "name": "Test App",
        "redirectUris": ["http://localhost:3001/callback"]
      },
      "assert": {
        "status": 401
      }
    },
    {
      "name": "OIDC Clients — 查詢不存在的 client 應回 401（無 token）",
      "method": "GET",
      "path": "/auth/oidc-clients/nonexistent-id",
      "assert": {
        "status": 401
      }
    }
  ]
}
