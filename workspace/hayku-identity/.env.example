# hayku-identity 服務專屬設定
# 共用變數（JWT_SECRET, BCRYPT_ROUNDS 等）從根目錄 .env 繼承
PORT=3100
DATABASE_URL=postgres://hayku:hayku123@localhost:5432/hayku_identity

# 預設管理員（首次啟動時自動建立，已有 superAdmin 時忽略）
# DEFAULT_ADMIN_EMAIL=admin@hayku.local
# DEFAULT_ADMIN_PASSWORD=change-this-password
# DEFAULT_ADMIN_NAME=Hayku Admin

# OIDC Server 設定
# OIDC_ISSUER=https://identity.example.com   # 預設 http://localhost:3100
# OIDC_SESSION_HOURS=8                        # Session 有效時間（小時）
# OIDC_PRIVATE_KEY=                           # RS256 私鑰（PEM 格式）；未設定時開發模式自動產生
# OIDC_KEY_ID=hayku-key-1                     # JWKS key ID

# Google OAuth（填入後自動啟用 Google 登入）
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://identity.example.com/oauth/callback/google

# LDAP / Active Directory（填入後自動啟用 AD 登入）
# LDAP_URL=ldap://dc.example.com:389
# LDAP_BIND_DN=CN=ServiceAccount,CN=Users,DC=example,DC=com
# LDAP_BIND_PASSWORD=
# LDAP_SEARCH_BASE=CN=Users,DC=example,DC=com
# LDAP_USER_FILTER=(mail={{email}})           # 預設 (mail={{email}})
