# ============================================================
# Hayku — 全域環境變數
# 複製為 .env 並填入實際值
# ============================================================

# 環境
NODE_ENV=development

# 認證
JWT_SECRET=change-this-to-a-random-secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=30
BCRYPT_ROUNDS=12

# 資料庫（共用 credentials，各服務有自己的 DATABASE_URL）
DB_HOST=localhost
DB_USER=hayku
DB_PASSWORD=hayku123

# LLM API Keys
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# 預設管理員（首次啟動時自動建立）
DEFAULT_ADMIN_EMAIL=admin@hayku.local
DEFAULT_ADMIN_PASSWORD=change-this-password
# DEFAULT_ADMIN_NAME=Hayku Admin

# 服務間通訊
IDENTITY_SERVICE_URL=http://localhost:3100
