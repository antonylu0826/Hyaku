# ============================================================
# Hayku — 全域環境變數
# 複製為 .env 並填入實際值
# ============================================================

# 環境
NODE_ENV=development

# 認證
JWT_SECRET=change-this-to-a-random-secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=30
BCRYPT_ROUNDS=12

# 資料庫（共用 credentials，各服務有自己的 DATABASE_URL）
DB_HOST=localhost
DB_USER=hayku
DB_PASSWORD=hayku123

# LLM API Keys
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# 預設管理員（首次啟動時自動建立）
DEFAULT_ADMIN_EMAIL=admin@hayku.local
DEFAULT_ADMIN_PASSWORD=change-this-password
# DEFAULT_ADMIN_NAME=Hayku Admin

# 服務間通訊
IDENTITY_SERVICE_URL=http://localhost:3100

# ── OIDC Server（hayku-identity）──────────────────────────────
# 對外公開的 issuer URL（業務服務用來驗證 token）
OIDC_ISSUER=http://localhost:3100
# SSO Session 有效時間（小時，預設 8）
OIDC_SESSION_HOURS=8
# RS256 私鑰（PEM 格式，不設定則開發模式自動產生）
# OIDC_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
# JWKS key ID（供輪換金鑰使用）
OIDC_KEY_ID=hayku-key-1

# ── Google OAuth（不設定則停用）─────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3100/oauth/callback/google

# ── LDAP / Active Directory（不設定則停用）──────────────────
# LDAP_URL=ldap://dc.example.com:389
# LDAP_BIND_DN=CN=ServiceAccount,CN=Users,DC=example,DC=com
# LDAP_BIND_PASSWORD=
# LDAP_SEARCH_BASE=CN=Users,DC=example,DC=com
# LDAP_USER_FILTER=(mail={{email}})
